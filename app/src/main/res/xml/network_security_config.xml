<?xml version="1.0" encoding="utf-8"?>
<!--
    Production network security config.
    HTTPS only. No cleartext allowed for any domain.
    Debug builds override this via src/debug/res/xml/network_security_config.xml.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
